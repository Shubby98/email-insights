IMAP_HOST=imap.gmail.com
IMAP_USER=your_email@gmail.com
IMAP_PASSWORD=your_app_password_here
IMAP_PORT=993
IMAP_MAILBOX=INBOX

# --- Local LLM Provider ---
LLM_PROVIDER=lmstudio          # lmstudio (default) | ollama

# Optional overrides:
# LLM_MODEL=google/gemma-3-4b
# LLM_BASE_URL=http://127.0.0.1:10101

# For Ollama, set:
# LLM_PROVIDER=ollama
# LLM_MODEL=gemma3:4b
